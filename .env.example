# App
LEGAL_APP_NAME=Legal Checker API
LEGAL_APP_VERSION=0.1.0

# NER model for transformers token-classification pipeline.
# Example model:
# - nesemenpolkov/msu-wiki-ner
# Put an empty value to run regex-only mode.
LEGAL_NER_MODEL_NAME=
LEGAL_NER_MIN_SCORE=0.6
LEGAL_NER_DEVICE=-1

# LLM provider settings.
# Current runtime flow:
# 1. OpenRouter if LEGAL_OPENROUTER_API_KEY is set
# 2. fallback to local vLLM if LEGAL_VLLM_BASE_URL is reachable
# 3. fallback to built-in local template output otherwise
LEGAL_LLM_PROVIDER=openrouter
LEGAL_LLM_MODEL=openai/gpt-4o-mini
LEGAL_LLM_TIMEOUT_SEC=20
LEGAL_LLM_MAX_RETRIES=2

# OpenRouter
LEGAL_OPENROUTER_API_KEY=
LEGAL_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LEGAL_OPENROUTER_HTTP_REFERER=
LEGAL_OPENROUTER_TITLE=Legal Checker API

# Local vLLM-compatible endpoint
LEGAL_VLLM_BASE_URL=http://localhost:8000/v1
LEGAL_VLLM_API_KEY=local-token
LEGAL_VLLM_MODEL=local-model

# Retrieval / trusted sources
LEGAL_RETRIEVER_TIMEOUT_SEC=8
LEGAL_RETRIEVER_TOP_K=3
LEGAL_ALLOWED_SOURCE_DOMAINS=pravo.gov.ru,consultant.ru,garant.ru

# Tavily web search
LEGAL_TAVILY_API_KEY=
LEGAL_TAVILY_BASE_URL=https://api.tavily.com

# OCR and storage
LEGAL_OCR_ENABLED=true
LEGAL_STORAGE_DIR=.artifacts

# Optional extra entropy for DPAPI encryption on Windows
LEGAL_STORAGE_ENCRYPTION_KEY=
